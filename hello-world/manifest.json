{
  "manifest_version": 2,
  "name": "Hello World",
  "version": "1.0.0",
  "description": "Hello World test extension for Firefox",
  "browser_specific_settings": {
    "gecko": {
      "id": "hello-world-test@tabsync",
      "strict_min_version": "115.0"
    },
    "gecko_android": {}
  },
  "permissions": ["storage", "tabs"],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Hello World"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  }
}
