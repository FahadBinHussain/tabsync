{
  "manifest_version": 2,
  "name": "TabSync",
  "version": "1.0.10",
  "description": "Sync your open tabs across devices",
  "browser_specific_settings": {
    "gecko": {
      "id": "tabsync@yourdomain.com",
      "strict_min_version": "115.0"
    },
    "gecko_android": {}
  },
  "permissions": [
    "storage"
  ],
  "browser_action": {
    "default_popup": "index.html",
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "128": "icons/icon-128.png"
  }
}
